# BoobsOS — .gitignore

# Paczki RPM (artefakty budowania)
packages/out/

# Artefakty generowania ISO / obrazów dysków
*.iso
*.qcow2
*.raw
*.vmdk
*.vhd
*.vhdx
output/

# Artefakty buildah/podman
.buildah-cache/
containers-storage/

# Artefakty VM / podglądu (lokalne, nie do repo)
bib-output/
*.fd
vm-serial.log
*.err

# Pliki tymczasowe systemu
.DS_Store
Thumbs.db
*~
*.swp
*.swo
*.bak
*.orig

# Logi i debug
*.log
*.tmp

# Środowisko lokalne / sekrety
.env
.env.local
secrets/

# IDE
.idea/
.vscode/
*.code-workspace

# Wynik bib ISO
iso-output/

# Dane sesji Claude Code (lokalne, nie do repo)
.claude/

# Lokalna konfiguracja rejestru z insecure access (dev-only, nie commitować)
insecure-reg.conf
